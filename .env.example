# ─── DIKLY Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_BASE_URL=https://dikly.live
MONITOR_BASE_URL=https://monitor.dikly.live

# ── Database ──────────────────────────────────────────────────────────────────
# When using Docker Compose (docker-compose.yml), override with the service name:
# MONGODB_URI=mongodb://mongo:27017/dikly
# REDIS_URL=redis://redis:6379
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dikly?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379

# ── Auth & Tokens ─────────────────────────────────────────────────────────────
# Must be a long random string (≥ 64 chars). Change immediately after setup.
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-characters-long
JWT_EXPIRES_IN=7d
# Separate secret for short-lived meeting join tokens
MEETING_TOKEN_SECRET=another-long-random-string-for-meeting-join-tokens

# ── Jitsi Self-Hosted ─────────────────────────────────────────────────────────
# Leave JITSI_APP_SECRET blank → falls back to public meet.jit.si (no JWT auth).
# All three must be set together to enable self-hosted mode.

# Domain of your self-hosted Jitsi server (e.g. meet.yourdomain.com).
JITSI_DOMAIN=meet.yourdomain.com

# Application ID — must match JWT_APP_ID in docker-compose.jitsi.yml.
JITSI_APP_ID=dikly

# Shared secret — must match JWT_APP_SECRET in docker-compose.jitsi.yml.
# Generate with: openssl rand -hex 32
JITSI_APP_SECRET=your-prosody-jwt-app-secret

# Jicofo REST API for server-side participant kick.
# Only set when Jicofo is reachable from the DIKLY backend (same server or VPN).
# Expose only on localhost in docker-compose.jitsi.yml.
JITSI_JICOFO_URL=http://127.0.0.1:8888

# ── Jitsi Docker Stack ────────────────────────────────────────────────────────
# These are used by docker-compose.jitsi.yml on the Jitsi server.
# JITSI_APP_ID and JITSI_APP_SECRET must be identical to the values above.

# Generate all three with: openssl rand -hex 24
JICOFO_AUTH_PASSWORD=strong-random-password-for-jicofo
JICOFO_COMPONENT_SECRET=strong-random-secret-for-jicofo-component
JVB_AUTH_PASSWORD=strong-random-password-for-jvb

# Public IP of the Jitsi VM (required when behind NAT / cloud provider).
JVB_ADVERTISE_IPS=1.2.3.4

# Set to 1 to auto-provision a Let's Encrypt TLS certificate.
ENABLE_LETSENCRYPT=1
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Path for Jitsi Docker volume mounts.
CONFIG=./jitsi-config

# ── Email ─────────────────────────────────────────────────────────────────────
MAILERSEND_API_KEY=
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ── SMS ───────────────────────────────────────────────────────────────────────
# Set SMS_PROVIDER to switch between providers. Default: arkesel
# SMS_PROVIDER=arkesel   → set ARKESEL_API_KEY
# SMS_PROVIDER=mnotify   → set MNOTIFY_API_KEY
SMS_PROVIDER=arkesel
SMS_SENDER_ID=DIKLY

# Arkesel (https://arkesel.com)
ARKESEL_API_KEY=

# mNotify (https://app.mnotify.com/dashboard/account/api)
MNOTIFY_API_KEY=

# ── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Uncomment to disable the legacy proctored quiz system (superseded by SnapQuiz).
# LEGACY_PROCTOR_DISABLED=true

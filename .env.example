# ─── DIKLY Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Primary platform domain (app/api/admin/monitor subdomains)
PLATFORM_DOMAIN=dikly.sbs
APP_BASE_URL=https://app.dikly.sbs
API_BASE_URL=https://api.dikly.sbs
MONITOR_BASE_URL=https://monitor.dikly.sbs
ADMIN_BASE_URL=https://admin.dikly.sbs

# Legacy dikly.live domains (still supported for backwards compatibility)
# APP_BASE_URL=https://dikly.live
# MONITOR_BASE_URL=https://monitor.dikly.live

# ── Database ──────────────────────────────────────────────────────────────────
# When using Docker Compose (docker-compose.yml), override with the service name:
# MONGODB_URI=mongodb://mongo:27017/dikly
# REDIS_URL=redis://redis:6379
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dikly?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379

# ── Auth & Tokens ─────────────────────────────────────────────────────────────
# Must be a long random string (≥ 64 chars). Change immediately after setup.
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Separate secret for refresh tokens (REQUIRED for token security — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_REFRESH_SECRET=change-me-to-another-long-random-string-for-refresh-tokens
# Separate secret for short-lived meeting join tokens
MEETING_TOKEN_SECRET=another-long-random-string-for-meeting-join-tokens

# ── Jitsi (optional fallback — only needed if GetStream is NOT configured) ────
# GetStream is the primary video provider. Jitsi is used only as fallback when
# STREAM_API_KEY / STREAM_API_SECRET are absent.
JITSI_DOMAIN=meet.dikly.live
JITSI_APP_ID=dikly
JITSI_APP_SECRET=your-prosody-jwt-app-secret

# ── Email ─────────────────────────────────────────────────────────────────────
MAILERSEND_API_KEY=
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ── SMS ───────────────────────────────────────────────────────────────────────
# Set SMS_PROVIDER to switch between providers. Default: arkesel
# SMS_PROVIDER=arkesel   → set ARKESEL_API_KEY
# SMS_PROVIDER=mnotify   → set MNOTIFY_API_KEY
SMS_PROVIDER=arkesel
SMS_SENDER_ID=DIKLY

# Arkesel (https://arkesel.com)
ARKESEL_API_KEY=

# mNotify (https://app.mnotify.com/dashboard/account/api)
MNOTIFY_API_KEY=

# ── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── LiveKit Video ─────────────────────────────────────────────────────────────
# When set, LiveKit replaces Jitsi for all meeting calls.
# Sign up free at https://livekit.io/cloud
# LIVEKIT_URL must start with wss://
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# ── GetStream Video ───────────────────────────────────────────────────────────
# Primary video provider. When set, overrides Jitsi/LiveKit for meeting calls.
# Sign up at https://getstream.io/video/
STREAM_API_KEY=your-getstream-api-key
STREAM_API_SECRET=your-getstream-api-secret

# ── Cloudinary (image/media storage) ─────────────────────────────────────────
# Used for profile photos, company logos, question bank images, and chat
# images (src/services/storage/mediaStorage.js). Sign up free at
# https://cloudinary.com — Dashboard shows all three values.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Powers real OS-level push notifications (ArrivalIQ and future push-based
# features) that reach the client even when the app/tab is closed, via the
# service worker's push handler (src/public/sw.js). Generate a keypair once
# with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Never rotate an existing key without also re-subscribing every client —
# old subscriptions become invalid.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@dikly.sbs

# ── Firebase Cloud Messaging (native push for the Electron desktop app) ───────
# Standard Web Push (above) doesn't work inside Electron — its bundled
# Chromium has no Google push-service credentials, so pushManager.subscribe()
# always fails with "Registration failed - push service not available".
# The desktop app instead registers with real FCM via electron-push-receiver
# (see electron/main.js, electron/preload.js) and the server delivers to it
# through src/services/push/providers/fcmProvider.js.
#
# To set these up:
#   1. https://console.firebase.google.com → Add project (any name/plan; the
#      free Spark plan is enough).
#   2. Project settings (gear icon) → General tab → "Your apps" → Add app →
#      Web (</>) → register it (no hosting setup needed) → copy the
#      "Project ID" and the numeric "Sender ID" shown in the config snippet.
#      → FIREBASE_PROJECT_ID, FIREBASE_SENDER_ID
#   3. Project settings → Service accounts tab → Generate new private key →
#      downloads a JSON file. Open it and copy:
#        "project_id"   → FIREBASE_PROJECT_ID (same value as step 2)
#        "client_email" → FIREBASE_CLIENT_EMAIL
#        "private_key"  → FIREBASE_PRIVATE_KEY (keep the \n sequences as-is;
#                          the app converts them to real newlines at boot)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SENDER_ID=

# ── Traffic / travel-time (ArrivalIQ) ─────────────────────────────────────────
# Pick ONE provider. All three live behind src/services/traffic/trafficService.js,
# so switching later needs no code changes. Without any set, ArrivalIQ still
# runs but every prediction is skipped (skipReason: traffic_lookup_failed).
#
# Option A — Google Maps Distance Matrix: most accurate traffic data, but
# requires a Google Cloud billing account (a real signup hurdle for some
# regions/cards).
GOOGLE_MAPS_API_KEY=
#
# Option B — Mapbox Directions: no billing-account gate, usable token
# immediately on signup, generous free tier (100k requests/month) — but
# signup still asks for a card on file.
MAPBOX_ACCESS_TOKEN=
#
# Option C — TomTom Routing: signup needs only an email, no card at all,
# for its free tier (2,500 requests/day).
TOMTOM_API_KEY=
#
# Force which one to use if more than one happens to be set
# (google-maps | mapbox | tomtom). Leave blank to auto-pick whichever has
# a credential (Google Maps wins ties, then Mapbox, then TomTom).
TRAFFIC_PROVIDER=

# ── Meetings ──────────────────────────────────────────────────────────────────
# Base URL for the meeting room frontend (used in invite links)
MEET_BASE_URL=https://meet.dikly.sbs

# ── AI (Anthropic Claude) — quiz generation, exam proctoring, FAQ widget,
# and the fallback provider for Dikly AI's report/insights router below ────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Dikly AI report/insights router (src/services/ai/aiRouter.js) ──────────────
# Optional — Dikly AI keeps working on Claude alone if these are unset.
# Gemini Flash handles general writing/analysis (report narratives, everyday
# "Ask Dikly AI" questions); DeepSeek handles technical/coding-flavored
# questions, auto-detected from the question text. Neither key set → Claude
# handles everything, same as before this router existed.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI (GPT-o1 PR review in CI) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CI / Security Scanning ────────────────────────────────────────────────────
# Required by GitHub Actions security workflows.
# SEMGREP_APP_TOKEN → https://semgrep.dev/orgs/-/settings/tokens
# SONAR_TOKEN     → https://sonarcloud.io/account/security
SEMGREP_APP_TOKEN=your-semgrep-app-token
SONAR_TOKEN=your-sonar-token

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Uncomment to disable the legacy proctored quiz system (superseded by SnapQuiz).
# LEGACY_PROCTOR_DISABLED=true

# ── WebSocket Monitoring ──────────────────────────────────────────────────────
# Port for WebSocket upgrade (same server, handled by HTTP upgrade)
# No separate port needed — ws upgrades on the same Express HTTP server

# ── Docker Stack ──────────────────────────────────────────────────────────────
# MongoDB root credentials (used when running via docker-compose.yml)
MONGO_ROOT_USER=dikly
MONGO_ROOT_PASSWORD=change-me-strong-mongo-password

# Redis password (used for pub/sub in docker-compose.yml)
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379

# ── Subdomain Base ────────────────────────────────────────────────────────────
# Update server CORS origins — set to your actual domains
APP_BASE_URL=https://dikly.live
APP_SUBDOMAIN_APP=https://app.dikly.live
APP_SUBDOMAIN_MONITOR=https://monitor.dikly.live
APP_SUBDOMAIN_API=https://api.dikly.live
APP_SUBDOMAIN_ADMIN=https://admin.dikly.live

# ── CI/CD ─────────────────────────────────────────────────────────────────────
# Random secret that GitHub Actions sends to trigger deploys via the webhook.
# Generate with: openssl rand -hex 32
DEPLOY_TOKEN=

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# Sign up free at https://sentry.io → create a Node.js project → copy the DSN.
# Leave blank to disable Sentry (errors still logged locally via Winston).
SENTRY_DSN=

# ── Database Backups ──────────────────────────────────────────────────────────
# Directory where mongodump archives are stored locally (must be writable).
BACKUP_DIR=/var/backups/dikly
# Number of days to keep local backup archives before deleting them.
BACKUP_RETAIN_DAYS=7
# Optional: S3 bucket to upload backups to (e.g. s3://my-dikly-backups).
# Requires aws-cli installed and IAM credentials configured on the server.
# Leave blank to keep backups local only.
BACKUP_S3_BUCKET=

# Jitsi stack env — copy to ~/jitsi/.env on the VPS and fill in real values
# Generate passwords with: openssl rand -hex 24

JITSI_DOMAIN=meet.dikly.live
JITSI_APP_ID=dikly

# MUST match JITSI_APP_SECRET in the DIKLY app .env on this server
# Generate: openssl rand -hex 32
JITSI_APP_SECRET=REPLACE_WITH_STRONG_SECRET

JICOFO_AUTH_PASSWORD=REPLACE_WITH_RANDOM
JICOFO_COMPONENT_SECRET=REPLACE_WITH_RANDOM
JVB_AUTH_PASSWORD=REPLACE_WITH_RANDOM

# Public IP of this VPS (required for WebRTC behind NAT)
JVB_ADVERTISE_IPS=194.163.172.76

# HTTP port Jitsi web container binds to (nginx proxies this)
HTTP_PORT=8080

TZ=Africa/Accra
